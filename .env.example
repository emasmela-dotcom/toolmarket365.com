# Database
DATABASE_URL=postgresql://user:password@host/database

# Instagram API Configuration (for Instagram Scheduler)
INSTAGRAM_APP_ID=your-instagram-app-id-here
INSTAGRAM_APP_SECRET=your-instagram-app-secret-here
INSTAGRAM_REDIRECT_URI=http://localhost:3000/api/instagram/auth/callback

# Public Instagram App ID (for OAuth redirect)
NEXT_PUBLIC_INSTAGRAM_APP_ID=your-instagram-app-id-here

# Cron Job Security (for scheduled Instagram posting)
CRON_SECRET=your-secure-random-string-here

# Session Cookie (for authentication)
SESSION_SECRET=your-session-secret-here
