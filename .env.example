# Database
DATABASE_URL=postgresql://user:password@host/database

# Session Cookie (for authentication)
SESSION_SECRET=your-session-secret-here

# ============================================
# Production / .com launch (set when going live):
# ============================================
# Canonical site URL. Used for password reset links, Open Graph, sitemap.
# Local: leave unset or use http://localhost:3000
# Production: https://creatorflow365.com (or your custom domain)
NEXT_PUBLIC_SITE_URL=

# ============================================
# Optional (for full functionality):
# ============================================

# CRON_SECRET — only if using scheduled Instagram posts
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=your-secure-random-string-here

# INSTAGRAM_APP_ID, INSTAGRAM_APP_SECRET — only if using Instagram features
# Local: use http://localhost:3000/api/instagram/auth/callback
# Production: use https://yourdomain.com/api/instagram/auth/callback (must match Facebook app)
INSTAGRAM_APP_ID=your-instagram-app-id-here
INSTAGRAM_APP_SECRET=your-instagram-app-secret-here
INSTAGRAM_REDIRECT_URI=http://localhost:3000/api/instagram/auth/callback
NEXT_PUBLIC_INSTAGRAM_APP_ID=your-instagram-app-id-here

# OPENAI_API_KEY — optional: used by CreatorFlow Assistant (/assistant). If unset, users can add their own key in Dashboard.
# OPENAI_API_KEY=sk-...

# CLOUDINARY_CLOUD_NAME, CLOUDINARY_API_KEY, CLOUDINARY_API_SECRET — only if using image uploads
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
